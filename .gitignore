# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python and misc
__pycache__/
*.py[cod]
*$py.class
nul
git_status*.txt

# python compiled / cache
*.pyc
*.pyo
*.pyd
backend/__pycache__/
backend/**/__pycache__/

# SQLite database files (runtime data, not code)
*.db
*.sqlite
*.sqlite3

# NetCDF / oceanographic data files (large binary, ingested at runtime)
*.nc
*.nc4
*.netcdf
data/argo/
data/bgc/
data/wod/

# Python virtual environments
.venv/
venv/
env/

# OS
Thumbs.db
.DS_Store
